# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (JAMAIS exposer côté client). Requis pour :
#   - Génération + upload du PDF KYC post-signature (/api/kyc/sign-public).
#   - Émission de signed URLs pour téléchargement par les consultants
#     (/api/kyc/pdf/[clientId]).
# En l'absence de cette clé, la signature KYC fonctionne toujours mais
# le PDF n'est pas généré (warning log côté serveur).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
